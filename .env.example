# OpenAI / LLM
OPENAI_API_KEY=

# Tavily
TAVILY_API_KEY=

# Gmail OAuth
GOOGLE_APPLICATION_CREDENTIALS=./credentials/credentials.json
GMAIL_TOKEN=./credentials/token.json

# Email metadata
SQA_EMAIL_RECIPIENT=
SQA_EMAIL_SENDER=

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/sales_qualification

# Auth / JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
APP_PUBLIC_BASE_URL=http://localhost:8501

# Optional SMTP fallback
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=no-reply@example.com
